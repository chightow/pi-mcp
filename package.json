{
	"name": "pi-mcp",
	"version": "1.0.0",
	"description": "MCP server integration for pi — connect any MCP server and use its tools",
	"type": "module",
	"keywords": [
		"pi-package"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/earendil-works/pi-mcp"
	},
	"main": "./index.ts",
	"types": "./index.ts",
	"files": [
		"index.ts",
		"src"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"check": "tsc --noEmit",
		"test": "node --test --experimental-strip-types test/*.test.ts"
	},
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"typebox": "1.1.38"
	},
	"devDependencies": {
		"@types/node": "22.15.17",
		"typescript": "5.8.3"
	},
	"dependencies": {
		"@modelcontextprotocol/client": "2.0.0-beta.2"
	}
}
